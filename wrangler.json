{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "rbxchat",
	"main": "src/index.ts",
	"compatibility_date": "2025-10-08",
	"upload_source_maps": true,
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["MyDurableObject"]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": ["ChatRoom"],
			"deleted_classes": ["MyDurableObject"]
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "ChatRoom",
				"name": "CHAT_ROOM"
			}
		]
	},
	"observability": {
		"enabled": true
	}
}
